      "Bash(cp node_modules/@fontsource/oswald/files/oswald-latin-500-normal.woff2 src/assets/fonts/oswald-500.woff2)",
      "Bash(cp node_modules/@fontsource/oswald/files/oswald-latin-700-normal.woff2 src/assets/fonts/oswald-700.woff2)",
      "Bash(cp node_modules/@fontsource/jetbrains-mono/files/jetbrains-mono-latin-700-normal.woff2 src/assets/fonts/jetbrains-mono-700.woff2)",
      "Bash(awk '{print $5, $9}')",
      "Bash(cp node_modules/@fontsource/oswald/LICENSE src/assets/fonts/licenses/oswald-OFL.txt)",
      "Bash(cp node_modules/@fontsource/jetbrains-mono/LICENSE src/assets/fonts/licenses/jetbrains-mono-OFL.txt)",
      "Bash(cp node_modules/@fontsource/roboto-mono/LICENSE src/assets/fonts/licenses/roboto-mono-OFL.txt)",
      "Bash(cp node_modules/@fontsource/space-mono/LICENSE src/assets/fonts/licenses/space-mono-OFL.txt)",
      "Bash(cp node_modules/@fontsource/inter/LICENSE src/assets/fonts/licenses/inter-OFL.txt)",
      "Bash(node --input-type=module -e \"import\\('./src/renderer/renderer.js'\\).catch\\(e=>console.error\\(e.message\\)\\)\")",
      "Bash(node --input-type=module --check)",
      "Bash(echo \"exit: $?\")"
    ]
  }
