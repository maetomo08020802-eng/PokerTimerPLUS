      "Bash(node --check src/renderer/audio.js)",
      "Bash(node --check src/renderer/timer.js)",
      "Bash(node --check src/renderer/state.js)",
      "Bash(npm install *)",
      "Bash(grep -v '\\\\.woff$')",
      "Bash(grep '800-normal\\\\.woff2$')",
      "Bash(grep -E 'latin-\\(700|800\\)-normal\\\\.woff2$')",
      "Bash(mkdir -p src/assets/fonts/licenses)",
