{
  "name": "pokertimerplus",
  "productName": "PokerTimerPLUS+",
  "version": "1.3.0",
  "description": "Free poker tournament clock — presented by Yu Shitamachi / PLUS2",
  "author": "Yu Shitamachi (PLUS2)",
  "license": "UNLICENSED",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:icon": "node build/generate-icon.js",
    "test": "node tests/data-transfer.test.js && node tests/runtime-preservation.test.js && node tests/audit-fix.test.js && node tests/paused-flow.test.js && node tests/race-fixes.test.js && node tests/light-todos.test.js && node tests/editable-state.test.js && node tests/audit-residuals.test.js && node tests/new-tournament-edit.test.js && node tests/v130-features.test.js && node tests/c13-bg-image.test.js && node tests/c14-slideshow.test.js && node tests/c16-features.test.js && node tests/c17-audio-resume.test.js && node tests/c18-runtime-persistence.test.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.shitamachi.pokertimerplus",
    "productName": "PokerTimerPLUS+",
    "copyright": "© 2026 Yu Shitamachi / PLUS2",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!src/renderer/__layout-check.js",
      "!tests/**/*",
      "!scripts/**/*"
    ],
    "win": {
      "target": "nsis",
      "publisherName": "Yu Shitamachi",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "PokerTimerPLUS+",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "maetomo08020802-eng",
      "repo": "PokerTimerPLUS"
    }
  }
}
